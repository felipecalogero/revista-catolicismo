Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forçar tudo para /public
    RewriteRule ^$ public/index.php [L]

    RewriteCond %{REQUEST_URI} !^/public/

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>